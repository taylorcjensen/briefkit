---
import reportCss from '../styles/report.css?raw';

export interface NavPage {
  title: string;
  route: string;
  current?: boolean;
}

export interface Heading {
  depth: number;
  slug: string;
  text: string;
}

export interface Props {
  title: string;
  reportTitle?: string;
  pages?: NavPage[];
  headings?: Heading[];
  description?: string;
  image?: string;
  author?: string;
  buildTime?: string;
  colorMode?: 'auto' | 'light' | 'dark';
  assetBase?: string;
}

const {
  title,
  reportTitle,
  pages = [],
  headings = [],
  description,
  image,
  author,
  buildTime,
  colorMode = 'auto',
  assetBase = './',
} = Astro.props;

const footerPrefix = author ? `Made by ${author} with` : 'Made with';
const briefkitUrl = 'https://github.com/taylorcjensen/briefkit';
const hasPageNav = pages.length > 1;
const hasToc = headings.length > 0;
const pageTitle = reportTitle && reportTitle !== title ? `${title} · ${reportTitle}` : title;
const isLocalPreviewUrl = Astro.url.hostname === 'localhost' || Astro.url.hostname === '127.0.0.1';
const canonicalUrl = isLocalPreviewUrl ? undefined : Astro.url.href;
const previewImageUrl = image && !isLocalPreviewUrl ? new URL(image, Astro.url).href : undefined;
const mermaidRuntimeUrl = `${assetBase}_briefkit/mermaid/mermaid.esm.min.mjs`;
---

<!doctype html>
<html lang="en" data-bk-theme={colorMode}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    {description && <meta name="description" content={description} />}
    <meta property="og:type" content="article" />
    <meta property="og:title" content={pageTitle} />
    {description && <meta property="og:description" content={description} />}
    {canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
    {previewImageUrl && <meta property="og:image" content={previewImageUrl} />}
    <meta name="twitter:card" content={previewImageUrl ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={pageTitle} />
    {description && <meta name="twitter:description" content={description} />}
    {previewImageUrl && <meta name="twitter:image" content={previewImageUrl} />}
    <style is:inline set:html={reportCss}></style>
  </head>
  <body>
    <script is:inline>
      (() => {
        const storageKey = 'briefkit-theme';
        const stored = localStorage.getItem(storageKey);
        if (stored === 'light' || stored === 'dark' || stored === 'auto') {
          document.documentElement.dataset.bkTheme = stored;
        }
      })();
    </script>
    <div class="bk-shell">
      <header class="bk-header">
        <div>
          {reportTitle && reportTitle !== title && <div class="bk-report-title">{reportTitle}</div>}
          <h1>{title}</h1>
        </div>
        <div class="bk-theme-toggle" aria-label="Color mode">
          <button type="button" data-bk-theme-button="light">Light</button>
          <button type="button" data-bk-theme-button="dark">Dark</button>
          <button type="button" data-bk-theme-button="auto">Auto</button>
        </div>
      </header>

      <div class="bk-layout">
        <main class="bk-content">
          <slot />
        </main>

        {(hasPageNav || hasToc) && (
          <aside class="bk-sidebar" aria-label="Report navigation">
            {hasPageNav && (
              <nav class="bk-nav" aria-label="Pages">
                <h2>Pages</h2>
                <ul>
                  {pages.map((page) => (
                    <li><a aria-current={page.current ? 'page' : undefined} href={page.route}>{page.title}</a></li>
                  ))}
                </ul>
              </nav>
            )}
            {hasToc && (
              <nav class="bk-nav" aria-label="On this page">
                <h2>On this page</h2>
                <ul>
                  {headings.map((heading) => (
                    <li class={`bk-toc-depth-${heading.depth}`}><a href={`#${heading.slug}`}>{heading.text}</a></li>
                  ))}
                </ul>
              </nav>
            )}
          </aside>
        )}
      </div>

      <footer class="bk-footer">{footerPrefix} <a href={briefkitUrl}>Briefkit</a> | {buildTime}</footer>
    </div>
    <script is:inline>
      (() => {
        const storageKey = 'briefkit-theme';
        const buttons = [...document.querySelectorAll('[data-bk-theme-button]')];
        const apply = (mode) => {
          document.documentElement.dataset.bkTheme = mode;
          localStorage.setItem(storageKey, mode);
          buttons.forEach((button) => {
            button.toggleAttribute('aria-pressed', button.dataset.bkThemeButton === mode);
          });
          window.dispatchEvent(new CustomEvent('briefkit:theme-change', { detail: { mode } }));
        };
        apply(document.documentElement.dataset.bkTheme || 'auto');
        buttons.forEach((button) => button.addEventListener('click', () => apply(button.dataset.bkThemeButton)));
      })();
    </script>
    <script is:inline type="module" data-bk-mermaid-url={mermaidRuntimeUrl}>
      const runtimeScript = document.currentScript;
      const mermaidUrl = runtimeScript?.dataset.bkMermaidUrl || './_briefkit/mermaid/mermaid.esm.min.mjs';
      const mermaidMediaQuery = window.matchMedia('(prefers-color-scheme: dark)');
      let mermaidModule;
      let mermaidRenderToken = 0;

      function isMermaidDarkMode() {
        const mode = document.documentElement.dataset.bkTheme || 'auto';
        return mode === 'dark' || (mode === 'auto' && mermaidMediaQuery.matches);
      }

      function mermaidThemeConfig() {
        const styles = getComputedStyle(document.documentElement);
        const color = (name) => styles.getPropertyValue(name).trim();
        return {
          startOnLoad: false,
          securityLevel: 'strict',
          theme: 'base',
          themeVariables: {
            background: color('--bk-paper'),
            mainBkg: color('--bk-paper'),
            primaryColor: color('--bk-head'),
            primaryTextColor: color('--bk-ink'),
            primaryBorderColor: color('--bk-line'),
            lineColor: color('--bk-muted'),
            secondaryColor: color('--bk-callout-bg'),
            tertiaryColor: color('--bk-bg'),
            fontFamily: 'ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif',
            darkMode: isMermaidDarkMode(),
          },
        };
      }

      async function loadMermaid() {
        mermaidModule ??= import(mermaidUrl).then((module) => module.default);
        return mermaidModule;
      }

      function createMermaidFallback(source, error) {
        const message = document.createElement('div');
        message.className = 'bk-mermaid-error-message';
        message.textContent = `Mermaid render failed: ${error instanceof Error ? error.message : 'Unknown error'}`;

        const fallback = document.createElement('pre');
        fallback.className = 'bk-mermaid-source bk-mermaid-source-error';
        fallback.textContent = source;
        return [message, fallback];
      }

      async function renderBriefkitMermaid() {
        const figures = [...document.querySelectorAll('[data-bk-mermaid-source]')];
        if (figures.length === 0) return;

        const themeKey = isMermaidDarkMode() ? 'dark' : 'light';
        const token = ++mermaidRenderToken;
        const mermaid = await loadMermaid();
        mermaid.initialize(mermaidThemeConfig());

        for (const [index, figure] of figures.entries()) {
          const source = figure.dataset.bkMermaidSource?.trim();
          const stage = figure.querySelector('.bk-mermaid-stage');
          if (!source || !stage) continue;
          if (figure.dataset.bkMermaidRenderedTheme === themeKey && figure.dataset.bkMermaidStatus === 'rendered') continue;

          figure.dataset.bkMermaidStatus = 'loading';
          stage.setAttribute('aria-busy', 'true');

          try {
            const renderId = `bk-mermaid-${token}-${index}`;
            const result = await mermaid.render(renderId, source);
            if (token !== mermaidRenderToken) return;

            const wrapper = document.createElement('div');
            wrapper.className = 'bk-mermaid-svg';
            wrapper.innerHTML = result.svg;
            stage.replaceChildren(wrapper);
            result.bindFunctions?.(stage);
            figure.dataset.bkMermaidRenderedTheme = themeKey;
            figure.dataset.bkMermaidStatus = 'rendered';
          } catch (error) {
            stage.replaceChildren(...createMermaidFallback(source, error));
            figure.dataset.bkMermaidStatus = 'error';
          } finally {
            stage.removeAttribute('aria-busy');
          }
        }
      }

      renderBriefkitMermaid();
      window.addEventListener('briefkit:theme-change', renderBriefkitMermaid);
      mermaidMediaQuery.addEventListener('change', () => {
        if ((document.documentElement.dataset.bkTheme || 'auto') === 'auto') renderBriefkitMermaid();
      });
    </script>
  </body>
</html>
