{
  "name": "briefkit",
  "version": "0.1.8",
  "description": "Static Markdown/MDX report-site toolkit for fast agent-authored briefs.",
  "keywords": [
    "agent",
    "astro",
    "brief",
    "markdown",
    "mdx",
    "report",
    "static-site"
  ],
  "homepage": "https://taylorcjensen.github.io/briefkit/",
  "bugs": {
    "url": "https://github.com/taylorcjensen/briefkit/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/taylorcjensen/briefkit.git"
  },
  "type": "module",
  "bin": {
    "briefkit": "bin/briefkit.js"
  },
  "exports": {
    ".": "./src/index.ts",
    "./styles.css": "./src/styles/report.css"
  },
  "files": [
    "bin",
    "src",
    "skills",
    "publish-server",
    "README.md"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx/esm --test \"test/**/*.test.ts\"",
    "astro:check": "astro check",
    "check": "npm run typecheck && npm run astro:check && npm test",
    "briefkit": "node --import tsx/esm ./bin/briefkit.js"
  },
  "dependencies": {
    "@astrojs/markdown-remark": "^7.2.1",
    "@astrojs/mdx": "^7.0.2",
    "astro": "^7.0.7",
    "gray-matter": "^4.0.3",
    "mermaid": "^11.16.0",
    "tsx": "^4.20.5",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@types/node": "^25.9.3",
    "typescript": "^5.9.2"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "license": "MIT"
}
